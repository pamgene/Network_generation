library(tidyverse)
source("R/helper.R")
uka_old <- read_csv("data/PamGene/UKA_0.0.1.csv") %>% clean_tercen_columns()
best_drug_per_target <- read_csv("data/Sensitivity/best_drug_per_target_with_smallest_ic50.csv")
clean_uka_to_kinograte <- function(uka, sens, control, fscore_cutoff = 2, del_cell = NULL){
# --- Handle both "X vs control" and "control vs X" in contrast, flip sign if control is left ---
uka_clean <- uka %>%
clean_tercen_columns() %>%
filter(`Median Final score` > fscore_cutoff) %>%
filter(str_detect(contrast, paste0(" vs ", control)) | str_detect(contrast, paste0(control, " vs "))) %>%
mutate(contrast = gsub(contrast, pattern = "-", replacement = "")) %>%
mutate(
control_left = str_detect(contrast, paste0("^", control, " vs ")),
cell_line = ifelse(control_left,
str_replace(contrast, paste0(control, " vs "), ""),
str_replace(contrast, paste0(" vs ", control), "")),
MKS = ifelse(control_left, -`Median Kinase Statistic`, `Median Kinase Statistic`)
) %>%
dplyr::select(cell_line, `Kinase Name`, `Median Kinase Statistic`, `Median Final score`) %>%
dplyr::rename("uniprotname" = "Kinase Name", 'LogFC' = "Median Kinase Statistic",
'fscore' = "Median Final score")
uka_clean$cell_line[uka_clean$cell_line == "MC-116"] <- "MC116"
uka_clean$cell_line[uka_clean$cell_line == "WSU-DLCL-2"] <- "WSU-DLCL2"
return(uka_clean)
}
clean_sens_to_kinograte <- function(sens, control, del_cell = NULL, best_drug_per_target){
sens_clean <- sens %>%
dplyr::rename('cell_line' = 'CELL_LINE_NAME',
"uniprotname" = "TARGET_1") %>%
filter(DRUG_ID %in% best_drug_per_target$DRUG_ID) # keep only one drug per target based on data availability and sd
# Filter for everything vs control and if control is test, reverse it
control_df <- sens_clean %>% filter(cell_line == control)
sens_clean <- sens_clean %>%
left_join(control_df, by = c("DRUG_ID", "uniprotname"), suffix = c("", ".control"))
# browser()
sens_clean <- sens_clean %>%
mutate(
LogFC = LN_IC50 - LN_IC50.control
) %>%
filter(cell_line != control,
!is.na(LogFC)) %>%
dplyr::select(cell_line, uniprotname, LogFC)
if(!is.null(del_cell)){
sens_clean <- sens_clean %>%
filter(!cell_line %in% del_cell)
}
return(sens_clean)
}
kin.input_uka_old <- clean_uka_to_kinograte(uka_old, control = 'RL')
kin.input_sens <- clean_sens_to_kinograte(d_sens_cells, control = 'RL', best_drug_per_target = best_drug_per_target)
idmap_uka <- read_csv("data/PamGene/idmap_id_entrez_uniname_kinase.csv") %>%
mutate(ID_orig = uniprot, data_from = "Kinase")
idmap_uka$entrezid <- as.character(idmap_uka$entrezid)
